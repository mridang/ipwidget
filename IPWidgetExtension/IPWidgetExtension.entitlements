<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Widget extensions run sandboxed. -->
	<key>com.apple.security.app-sandbox</key>
	<true/>
	<!-- Required so the extension's timeline provider can reach the IP lookup
	     service over the network. Without this the fetch silently fails. -->
	<key>com.apple.security.network.client</key>
	<true/>
</dict>
</plist>
