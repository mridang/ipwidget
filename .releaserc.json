{
  "branches": [
    "main"
  ],
  "plugins": [
    "@semantic-release/commit-analyzer",
    "@semantic-release/release-notes-generator",
    [
      "@semantic-release/exec",
      {
        "prepareCmd": "bash installer/build.sh ${nextRelease.version}"
      }
    ],
    [
      "@semantic-release/github",
      {
        "successComment": false,
        "failComment": false,
        "assets": [
          {
            "path": "IPWidget.pkg",
            "label": "IPWidget.pkg (macOS installer)"
          },
          {
            "path": "IPWidget.zip",
            "label": "IPWidget.app (macOS, drag-install)"
          }
        ]
      }
    ]
  ]
}
